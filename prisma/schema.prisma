generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//Creación de las tablas
model User {
  id_user      String     @id @default(uuid())
  password String
  name     String
  role     Roles
  email    String     @unique
}

enum Roles {
  ADMIN
  USER
  EMPLOYEE
}